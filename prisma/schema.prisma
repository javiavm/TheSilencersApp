// Schema de The Silencers: tablas NextAuth + dominio (User, Post, Resource, Server, Category).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum PostType {
  NEWS
  ANNOUNCEMENT
  GIVEAWAY
  RESULT
}

enum ResourceCategory {
  GUIDE
  MOD
  PLUGIN
  BUILD
  OTHER
}

enum Game {
  MINECRAFT
  DISCORD_BOT
  GENERAL
  OTHER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  // Campos estándar NextAuth — los rellena PrismaAdapter.
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Campos de dominio — username se rellena en events.createUser tras el insert.
  username      String?   @unique
  avatarUrl     String?
  bio           String?   @db.Text
  role          Role      @default(USER)
  discordId     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  posts     Post[]
  resources Resource[]
  servers   Server[]

  @@index([role])
}

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  icon     String?
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  resources Resource[]

  @@index([parentId])
}

model Post {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  content          Json      // rich text JSON (Tiptap)
  excerpt          String?   @db.Text
  type             PostType  @default(NEWS)
  tags             String[]  @default([])
  featuredImageUrl String?
  published        Boolean   @default(false)
  publishedAt      DateTime?
  authorId         String
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([authorId])
  @@index([type])
  @@index([published, publishedAt])
  @@index([slug])
}

model Resource {
  id            String           @id @default(cuid())
  title         String
  slug          String           @unique
  description   String           @db.Text
  category      ResourceCategory
  game          Game             @default(GENERAL)
  fileUrl       String?
  thumbnailUrl  String?
  version       String?
  size          Int?
  downloadCount Int              @default(0)
  published     Boolean          @default(true)
  authorId      String
  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId    String?
  categoryRef   Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([game])
  @@index([slug])
}

model Server {
  id            String   @id @default(cuid())
  name          String
  description   String   @db.Text
  game          Game     @default(MINECRAFT)
  ip            String?
  discordInvite String?
  bannerUrl     String?
  tags          String[] @default([])
  isVerified    Boolean  @default(false)
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([game])
  @@index([isVerified])
}
